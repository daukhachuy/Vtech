@{
    ViewData["Title"] = "Form";
}

@{
    var forms = ViewBag.Forms as List<PAS_APP.Models.Form>;
    var students = ViewBag.Data as List<PAS_APP.Models.Student>;
}


<!-- Main Content -->
<div class="main-content">
    <!-- Header -->
    <header class="header">
        <h1 class="header-title">Data</h1>
        <div class="search-container">
            <i class="fas fa-search search-icon"></i>
            <input type="text" class="search-input" placeholder="Search..." id="searchInput">
        </div>
        <div class="header-actions">
            <button class="notification-btn">
                <i class="fas fa-bell"></i>
                <span class="notification-badge">3</span>
            </button>
            <div class="user-profile">
                <img src="/placeholder.svg?height=32&width=32" alt="User" class="user-avatar">
                <div class="user-info">
                    <h6 id="userName">@ViewBag.Username</h6>
                </div>
            </div>
        </div>
    </header>

    <!-- Profile Content -->
    <table class="table table-bordered table-hover align-middle container">
        <thead class="table-primary">
            <tr>
                <th scope="col">Mã</th>
                <th scope="col">Ngày tạo</th>
                <th scope="col">Ngày hết hạn</th>
                <th scope="col">Thông tin</th>
                <th scope="col" class="text-center">Xem file</th>
                <th scope="col" class="text-center">Tải file</th> 
            </tr>
        </thead>
        <tbody>
            @foreach (var u in forms)
            {
                <tr>
                    <td>@u.FormId</td>
                    <td>@u.CreateAt</td>
                    <td>@u.Due</td>
                    <td>@u.Info</td>
                    <td class="text-center">
                        <a asp-controller="User"
                           asp-action="ReadForm"
                           asp-route-id="@u.FormId"
                           class="btn btn-sm btn-outline-primary">
                            Xem
                        </a>
                    </td>
                    <td class="text-center">
                        <button class="btn btn-sm btn-outline-success">Download</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>


    <div class="container mt-5">
        <div class="modal-header  ">
            <h3 class="modal-title  text-primary">Thông tin thí sinh đăng kí  </h3>

        </div>
        <table id="example" class="table table-striped table-bordered border  " style="width:100%">
            <thead>
                <tr>
                    <th>Tên Thí sinh</th>
                    <th>Thông tin thí sinh</th>
                    <th>Diểm , chứng chỉ</th>
                    <th>Liên lạc</th>                  
                    <th>Thông tin Gia đình</th>
                    <th>Giới thiệu bản thân</th>
                </tr>
            </thead>
            <tbody>
                @if(students == null)
                {
                    <tr>
                        
                            <div class="text-danger text-center">Hãy chọn danh sách thu thập phía trên</div>
                        
                    </tr>
                       
                            
                        

                    
                }else
                {
                    @foreach (var u in students)
                    {

                        <tr>
                            <td>@u.FullName</td>
                            <td>
                                <a>Giới tính : @u.Gender</a>
                                <a>Năm sinh: @u.BirthYear</a>
                                <a>Dân tộc: @u.Ethnicity</a>
                                <a>Địa chỉ thường trú : @u.PermanentAddress</a>
                            </td>
                            <td>
                                <a>Gpa Thpt : @u.GpaThpt</a>
                                <a>Ielts: @u.Ielts</a>
                                <a>Địa chỉ tạm trú: @u.CurrentAddress</a>
                                <a>Khác : @u.OtherCertificates</a>
                            </td>
                            <td>
                                <a>SDT : @u.Phone</a>
                                <a>Email: @u.Email</a>
                                <a>Toeic: @u.Toeic</a>
                                <a>Khác : @u.OtherCertificates</a>
                            </td>
                            <td>
                                <a>Họ tên bố  : @u.FatherName</a>
                                <a>Nghề nghiệp: @u.FatherOccupation</a>
                                <a>Họ tên mẹ: @u.MotherName</a>
                                <a>Nghề nghiệp : @u.MotherOccupation</a>
                            </td>
                            <td>@u.SelfIntroduction</td>
                        </tr>

                    }
                }              
                
                    </tbody>
            <tfoot>
                <tr>
                    <th>Tên Thí sinh</th>
                    <th>Thông tin thí sinh</th>
                    <th>Diểm , chứng chỉ</th>
                    <th>Liên lạc</th>
                    <th>Thông tin Gia đình</th>
                    <th>Giới thiệu bản thân</th>
                </tr>
            </tfoot>
        </table>

    </div>



    



</div>
