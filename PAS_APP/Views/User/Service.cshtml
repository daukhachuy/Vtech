@{
    ViewData["Title"] = "Home";

    // Serialize Model sang JSON, CreateAt thành ISO string
    var jsonServices = System.Text.Json.JsonSerializer.Serialize(
        Model.Select(s => new
        {
            serviceId = s.ServiceId,
            title = s.Title ?? "",
            detail = s.Detail ?? "",
            createAt = s.CreateAt.ToString("yyyy-MM-ddTHH:mm:ss")
        })
    );
}

@model List<Service>

<div class="main-content">
    <!-- Header -->
    <header class="header">
        <h1 class="header-title">Service</h1>
        <div class="search-container">
            <i class="fas fa-search search-icon"></i>
            <input type="text" class="search-input" placeholder="Search..." id="searchInput">
        </div>
        <div class="header-actions">
            <button class="notification-btn">
                <i class="fas fa-bell"></i>
                <span class="notification-badge">3</span>
            </button>
            <div class="user-profile">
                <img src="/placeholder.svg?height=32&width=32" alt="User" class="user-avatar">
                <div class="user-info">
                    <h6 id="userName">@ViewBag.Username</h6>
                </div>
            </div>
        </div>
    </header>

    <!-- Service Content -->
    <div class="container py-4">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h1 class="h4 m-0">List of service</h1>
            <div class="w-50 ms-3">
                <input id="search" class="form-control" placeholder="Search by title or description ...">
            </div>
        </div>

        <div id="servicesRow" class="row g-3"></div>

        <template id="cardTpl">
            <div class="col-12 col-sm-6 col-md-4">
                <div class="card card-service h-100">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title mb-1"></h5>
                        <p class="card-text truncate-2 mb-2"></p>
                        <div class="mt-auto d-flex justify-content-between align-items-center">
                            <div class="meta"></div>
                            <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#detailModal">Chi tiết</button>
                        </div>
                    </div>
                </div>
            </div>
        </template>

        <!-- Detail modal -->
        <div class="modal fade" id="detailModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Tiêu đề</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <p class="text-muted small mb-2"></p>
                        <p class="detail-body"></p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Chuyển Model sang JS
    const services = @Html.Raw(jsonServices);

    const servicesRow = document.getElementById('servicesRow');
    const tpl = document.getElementById('cardTpl');
    const searchInput = document.getElementById('search');
    const modalEl = document.getElementById('detailModal');

    // Hàm format ngày từ ISO string
    function formatDate(iso) {
        const d = new Date(iso);
        if (isNaN(d)) return "Invalid Date";
        return d.toLocaleString('vi-VN', {
            year: 'numeric',
            month: '2-digit',
            day: '2-digit',
            hour: '2-digit',
            minute: '2-digit'
        });
    }

    function render(list) {
        servicesRow.innerHTML = '';
        if (list.length === 0) {
            servicesRow.innerHTML = '<div class="col-12"><div class="alert alert-info mb-0">Không tìm thấy dịch vụ nào.</div></div>';
            return;
        }

        list.forEach(s => {
            const node = tpl.content.cloneNode(true);
            node.querySelector('.col-12').setAttribute('data-id', s.serviceId);
            node.querySelector('.card-title').textContent = s.title;
            node.querySelector('.card-text').textContent = s.detail;
            node.querySelector('.meta').textContent = 'Tạo: ' + formatDate(s.createAt);
            const btn = node.querySelector('button');
            btn.addEventListener('click', () => openDetail(s));
            servicesRow.appendChild(node);
        });
    }

    function openDetail(s) {
        modalEl.querySelector('.modal-title').textContent = s.title;
        modalEl.querySelector('.modal-body .small').textContent = 'Tạo: ' + formatDate(s.createAt);
        modalEl.querySelector('.detail-body').textContent = s.detail;
    }

    // Search/filter
    searchInput.addEventListener('input', (e) => {
        const q = e.target.value.trim().toLowerCase();
        const filtered = services.filter(s =>
            (s.title && s.title.toLowerCase().includes(q)) ||
            (s.detail && s.detail.toLowerCase().includes(q))
        );
        render(filtered);
    });

    // Initial render
    render(services);
</script>
